---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  SITE,
  STATS,
  FEATURES,
  AUDIENCES,
  PROVIDERS,
  AI_CONTEXT,
  ROADMAP,
  url,
} from "../lib/site";

const iconUrl = (k: string) => url(`/icons/sidebar/${k}.svg`);
---

<BaseLayout>
  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">GPU terminal workspace · built in Rust</p>
        <h1 class="hero-title">
          <span class="w" style="--i: 0"><span>The</span></span>
          <span class="w" style="--i: 1"
            ><span class="gradient-text gradient-flow">alternative</span></span
          >
          <span class="w" style="--i: 2"><span>terminal.</span></span>
        </h1>
        <p class="lead reveal" data-delay="120">
          Alterm pairs the workspace UX of WaveTerm — tiling blocks, AI chat, an embedded
          browser — with the raw, GPU-rendered speed of WezTerm.
          <strong>Without the Electron bloat.</strong>
        </p>
        <div class="hero-cta reveal" data-delay="180">
          <a class="btn btn-primary" href={url("/docs/installation")}>
            Get started
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
              ><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"
              ></path></svg
            >
          </a>
          <a class="btn btn-ghost" href={SITE.repo} target="_blank" rel="noopener">
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"
              ><path
                d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.8.06 1.23.83 1.23.83.71 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"
              ></path></svg
            >
            View on GitHub
          </a>
        </div>
        <p class="hero-meta reveal" data-delay="240">
          <span class="dotpulse"></span> v{SITE.version} · early access · Linux · macOS · Windows
        </p>
      </div>

      <div class="hero-demo reveal" data-reveal="right" data-delay="120">
        <div class="hero-tilt">
          <div class="hero-shot">
            <picture>
              <source srcset={url("/shots/split-4.webp")} type="image/webp" />
              <img
                src={url("/shots/split-4.png")}
                width="1600"
                height="845"
                alt="Alterm in a four-way tiling split — file browser, image preview, a terminal pane showing the ALTERM ascii banner, and an embedded browser on google.com, all in the dark purple theme."
                decoding="async"
                fetchpriority="high"
              />
            </picture>
            <span class="hero-glare" aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= STATS ================= -->
  <div class="stats-wrap">
    <div class="container stats reveal">
      {
        STATS.map((s) => (
          <div class="stat">
            <span class="stat-value" data-counter={s.value}>{s.value}</span>
            <span class="stat-label">{s.label}</span>
            {s.note && <span class="stat-note">{s.note}</span>}
          </div>
        ))
      }
    </div>
  </div>

  <!-- ================= FEATURES ================= -->
  <section id="features">
    <div class="container">
      <header class="sec-head reveal">
        <p class="eyebrow">Everything in one workspace</p>
        <h2 class="h-section">A terminal that <span class="gradient-text">grows with you</span>.</h2>
        <p class="lead">
          From a first clickable split to a scripted, AI-assisted power setup — Alterm meets
          beginners, intermediates, and experts where they are.
        </p>
      </header>

      <div class="feat-grid">
        {
          FEATURES.map((f, i) => (
            <article class="card feat reveal" data-delay={(i % 3) * 80}>
              <div class="feat-top">
                <span class="feat-icon">
                  {f.icon ? (
                    <span
                      class="icon"
                      style={`-webkit-mask-image:url(${iconUrl(f.icon)});mask-image:url(${iconUrl(f.icon)})`}
                    />
                  ) : (
                    <span class="glyph" />
                  )}
                </span>
                {f.status === "planned" ? (
                  <span class="tag tag-planned">planned</span>
                ) : (
                  <span class="tag tag-live">core</span>
                )}
              </div>
              <h3 class="feat-title">{f.title}</h3>
              <p class="feat-body">{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= AUDIENCES ================= -->
  <section class="audiences">
    <div class="container">
      <header class="sec-head center reveal">
        <p class="eyebrow">For every level</p>
        <h2 class="h-section">Three users, <span class="gradient-text">one workspace</span>.</h2>
      </header>
      <div class="aud-grid">
        {
          AUDIENCES.map((a, i) => (
            <article class="card aud reveal" data-delay={i * 90}>
              <span class="aud-num">0{i + 1}</span>
              <h3>{a.key}</h3>
              <p>{a.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= AI ================= -->
  <section id="ai" class="ai">
    <div class="container ai-grid">
      <div class="ai-copy reveal" data-reveal="left">
        <p class="eyebrow">Intelligence, in context</p>
        <h2 class="h-section">AI that can <span class="gradient-text">see your terminal</span>.</h2>
        <p class="lead">
          The chat block reads your focused terminal's output, so help is grounded in what's
          actually on screen — not a guess. Replies stream live from the provider of your choice.
        </p>
        <ul class="ai-context">
          {
            AI_CONTEXT.map((c) => (
              <li>
                <span class="ai-prompt">&gt;</span>
                <div>
                  <strong>{c.title}</strong>
                  <p>{c.body}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="ai-providers reveal" data-reveal="right" data-delay="120">
        <p class="prov-head">Bring your own provider</p>
        <div class="prov-list">
          {
            PROVIDERS.map((p) => (
              <span class={`prov ${p.kind}`}>
                <span class="prov-dot" />
                {p.name}
                <span class="prov-kind">{p.kind}</span>
              </span>
            ))
          }
        </div>
        <p class="prov-note">
          …or any OpenAI-compatible endpoint. Keys stay in your local config — never on a server.
        </p>
      </aside>
    </div>
  </section>

  <!-- ================= GALLERY (placeholder until screenshots) ================= -->
  <section class="gallery">
    <div class="container">
      <header class="sec-head center reveal">
        <p class="eyebrow">See it in action</p>
        <h2 class="h-section">One workspace, <span class="gradient-text">any split</span>.</h2>
        <p class="lead">
          Real captures of Alterm today — tile as many panes as you need: terminals, a file
          browser, image preview, an embedded web browser, and live settings.
        </p>
      </header>
      <div class="shots">
        {
          [
            { src: "split-4", label: "Four-way split", caption: "Files · image preview · terminal · browser" },
            { src: "split-5", label: "Five-way split", caption: "Adds a live settings panel" },
            { src: "split-6", label: "Six-way split", caption: "Plus a keybindings reference pane" },
          ].map((shot, i) => (
            <figure class={`shot reveal shot-${i}`} data-delay={(i % 2) * 80}>
              <picture>
                <source srcset={url(`/shots/${shot.src}.webp`)} type="image/webp" />
                <img
                  src={url(`/shots/${shot.src}.png`)}
                  width="1600"
                  height="845"
                  alt={`Alterm ${shot.label.toLowerCase()} — ${shot.caption}.`}
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <figcaption>
                <span class="shot-label">{shot.label}</span>
                <span class="shot-cap">{shot.caption}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= ROADMAP ================= -->
  <section id="roadmap" class="roadmap">
    <div class="container">
      <header class="sec-head reveal">
        <p class="eyebrow">Where it's going</p>
        <h2 class="h-section">A clear <span class="gradient-text">five-phase</span> path.</h2>
      </header>
      <ol class="timeline">
        {
          ROADMAP.map((r, i) => (
            <li class={`tl-item reveal ${r.status}`} data-delay={i * 70}>
              <span class="tl-node" />
              <div class="tl-card">
                <div class="tl-head">
                  <span class="tl-phase">{r.phase}</span>
                  {r.status === "done" && <span class="tag tag-live">shipped</span>}
                  {r.status === "current" && <span class="tag tag-current">in progress</span>}
                  {r.status === "upcoming" && <span class="tag tag-planned">planned</span>}
                </div>
                <h3>{r.name}</h3>
                <p>{r.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section class="final">
    <div class="container final-inner reveal">
      <h2>Build it from source today.</h2>
      <p class="lead">
        Alterm is MIT-licensed and open. Clone it, <code>cargo install</code>, and shape the
        alternative terminal with us.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={url("/docs/installation")}>Installation guide</a>
        <a class="btn btn-ghost" href={SITE.repo} target="_blank" rel="noopener">
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding-top: clamp(48px, 7vw, 92px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  /* Headline — each word clip-reveals up on load, staggered by --i */
  .hero-title {
    font-size: clamp(2.7rem, 6.2vw, 4.9rem);
    margin: 0.25em 0 0.35em;
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.26em;
    line-height: 1.04;
  }
  .hero-title .w {
    display: inline-flex;
    overflow: hidden;
    padding-block: 0.08em;
  }
  .hero-title .w > span {
    display: inline-block;
    transform: translateY(110%);
    animation: word-rise 0.95s cubic-bezier(0.2, 0.85, 0.25, 1) both;
    animation-delay: calc(0.15s + var(--i) * 0.1s);
  }
  @keyframes word-rise {
    to {
      transform: translateY(0);
    }
  }

  /* Hero screenshot — perspective stage, gentle float, pointer-driven 3D tilt + glare */
  .hero-demo {
    perspective: 1200px;
  }
  .hero-tilt {
    transform-style: preserve-3d;
    animation: hero-float 7s ease-in-out infinite;
    will-change: transform;
  }
  .hero-shot {
    position: relative;
    border-radius: 16px;
    padding: 1px;
    transform-style: preserve-3d;
    transform: rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg));
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
    background: linear-gradient(160deg, rgba(249, 119, 255, 0.55), rgba(86, 0, 141, 0.25) 55%, transparent);
    box-shadow:
      0 0 0 1px rgba(249, 119, 255, 0.08),
      0 30px 80px -30px rgba(86, 0, 141, 0.75),
      0 8px 30px -12px rgba(0, 0, 0, 0.7);
  }
  /* While actively tracking the pointer, drop the easing so it follows 1:1. */
  .hero-tilt.is-tilting .hero-shot {
    transition: none;
  }
  .hero-shot::before {
    content: "";
    position: absolute;
    inset: -16%;
    z-index: -1;
    background: radial-gradient(60% 55% at 65% 40%, rgba(249, 119, 255, 0.22), transparent 70%);
    filter: blur(6px);
    pointer-events: none;
  }
  .hero-shot img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 15px;
  }
  /* Specular sheen that tracks the cursor across the glass. */
  .hero-glare {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: radial-gradient(
      circle at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 255, 255, 0.28),
      rgba(255, 255, 255, 0) 45%
    );
    opacity: var(--go, 0);
    mix-blend-mode: screen;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }
  .hero-cta svg {
    width: 1.05em;
    height: 1.05em;
  }
  .hero-meta {
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-faint);
    display: flex;
    align-items: center;
    gap: 0.6em;
  }
  .dotpulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--term-green);
    box-shadow: 0 0 0 0 rgba(94, 242, 176, 0.6);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    70% {
      box-shadow: 0 0 0 7px rgba(94, 242, 176, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(94, 242, 176, 0);
    }
  }

  /* ---------- Stats ---------- */
  .stats-wrap {
    border-block: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(86, 0, 141, 0.06), transparent);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
    padding-block: 30px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: center;
    position: relative;
  }
  .stat + .stat::before {
    content: "";
    position: absolute;
    left: -9px;
    top: 12%;
    height: 76%;
    width: 1px;
    background: var(--line);
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    font-weight: 700;
    background: var(--grad-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .stat-note {
    font-size: 0.68rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
  }

  /* ---------- Section heads ---------- */
  .sec-head {
    margin-bottom: 48px;
    max-width: 60ch;
  }
  .sec-head.center {
    margin-inline: auto;
    text-align: center;
  }
  .sec-head.center .lead {
    margin-inline: auto;
  }

  /* ---------- Features ---------- */
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .feat-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .feat-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: rgba(249, 119, 255, 0.08);
    border: 1px solid var(--line-bright);
    color: var(--accent);
  }
  .feat-icon .icon {
    width: 24px;
    height: 24px;
  }
  .glyph {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: var(--grad-chrome);
    box-shadow: 0 0 14px -2px var(--accent);
  }
  .feat-title {
    font-size: 1.18rem;
    margin-bottom: 0.5em;
  }
  .feat-body {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ---------- Audiences ---------- */
  .aud-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .aud-num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }
  .aud h3 {
    font-size: 1.5rem;
    margin: 0.3em 0 0.5em;
  }
  .aud p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ---------- AI ---------- */
  .ai-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.95fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .ai-context {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 32px;
  }
  .ai-context li {
    display: flex;
    gap: 14px;
  }
  .ai-prompt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 700;
    line-height: 1.5;
  }
  .ai-context strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
  }
  .ai-context p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 2px;
  }
  .ai-providers {
    background: linear-gradient(180deg, var(--bg-elev), var(--bg));
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 26px;
  }
  .prov-head {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 16px;
  }
  .prov-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .prov {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--bg);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .prov:hover {
    border-color: var(--accent);
    transform: translateX(3px);
  }
  .prov-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }
  .prov.local .prov-dot {
    background: var(--term-green);
    box-shadow: 0 0 8px var(--term-green);
  }
  .prov-kind {
    margin-left: auto;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }
  .prov-note {
    margin-top: 16px;
    font-size: 0.82rem;
    color: var(--text-faint);
  }

  /* ---------- Gallery ---------- */
  .shots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .shot {
    margin: 0;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: var(--bg-elev);
    overflow: hidden;
    position: relative;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .shot:hover {
    transform: translateY(-4px);
    border-color: rgba(249, 119, 255, 0.4);
    box-shadow: 0 20px 50px -24px rgba(86, 0, 141, 0.8);
  }
  .shot picture,
  .shot img {
    display: block;
    width: 100%;
    height: auto;
  }
  .shot img {
    border-bottom: 1px solid var(--line);
  }
  .shot figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 14px 16px;
  }
  .shot-label {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--text);
  }
  .shot-cap {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--text-faint);
  }

  /* ---------- Roadmap ---------- */
  .timeline {
    position: relative;
    display: grid;
    gap: 14px;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(180deg, var(--purple-core), var(--orchid), transparent);
    transform-origin: top;
  }
  /* With JS, the spine "draws" downward when the timeline scrolls into view.
     Without JS it's simply shown full (no gate applied). */
  :global(html.js) .timeline::before {
    transform: scaleY(0);
    transition: transform 1.2s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :global(html.js) .timeline.is-drawn::before {
    transform: scaleY(1);
  }
  .tl-item {
    position: relative;
    padding-left: 40px;
  }
  .tl-node {
    position: absolute;
    left: 0;
    top: 22px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--line-bright);
  }
  .tl-item.current .tl-node {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 0 4px rgba(249, 119, 255, 0.18), 0 0 16px var(--accent);
    animation: node-pulse 2.4s ease-out infinite;
  }
  @keyframes node-pulse {
    0% {
      box-shadow: 0 0 0 3px rgba(249, 119, 255, 0.25), 0 0 16px var(--accent);
    }
    70% {
      box-shadow: 0 0 0 13px rgba(249, 119, 255, 0), 0 0 16px var(--accent);
    }
    100% {
      box-shadow: 0 0 0 3px rgba(249, 119, 255, 0), 0 0 16px var(--accent);
    }
  }
  .tl-card {
    background: linear-gradient(180deg, var(--bg-elev), var(--bg));
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 22px;
  }
  .tl-item.current .tl-card {
    border-color: rgba(249, 119, 255, 0.3);
  }
  /* Completed phases — solid node, no pulse. */
  .tl-item.done .tl-node {
