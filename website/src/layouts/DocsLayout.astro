---
import BaseLayout from "./BaseLayout.astro";
import { url } from "../lib/site";

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;

const docsNav = [
  {
    group: "Getting started",
    items: [
      { label: "Overview", href: "/docs" },
      { label: "Installation", href: "/docs/installation" },
    ],
  },
  {
    group: "Reference",
    items: [
      { label: "Configuration", href: "/docs/configuration" },
      { label: "Keybindings", href: "/docs/keybindings" },
      { label: "AI providers", href: "/docs/ai" },
    ],
  },
];

// Normalise current path against base for active-link matching.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const current = Astro.url.pathname.replace(/\/$/, "") || base;
const isActive = (href: string) => url(href).replace(/\/$/, "") === current;
---

<BaseLayout title={title} description={description}>
  <div class="docs container">
    <aside class="docs-side">
      <nav aria-label="Documentation">
        {
          docsNav.map((g) => (
            <div class="nav-group">
              <p class="nav-group-title">{g.group}</p>
              <ul>
                {g.items.map((it) => (
                  <li>
                    <a href={url(it.href)} class={isActive(it.href) ? "active" : ""}>
                      {it.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </aside>

    <article class="docs-content">
      <header class="docs-header">
        <p class="eyebrow">Documentation</p>
        <h1>{title}</h1>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 230px 1fr;
    gap: 48px;
    padding-block: clamp(40px, 6vw, 72px) 80px;
    align-items: start;
  }
  .docs-side {
    position: sticky;
    top: 88px;
  }
  .nav-group + .nav-group {
    margin-top: 26px;
  }
  .nav-group-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 10px;
  }
  .docs-side ul {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .docs-side a {
    display: block;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 0.92rem;
    color: var(--text-muted);
    border-left: 2px solid transparent;
    transition: color 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .docs-side a:hover {
    color: var(--text);
    background: rgba(249, 119, 255, 0.06);
  }
  .docs-side a.active {
    color: var(--accent);
    border-left-color: var(--accent);
    background: rgba(249, 119, 255, 0.08);
  }
  .docs-header {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }
  .docs-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-top: 0.3em;
  }

  /* prose */
  .prose {
    max-width: 70ch;
    font-size: 1rem;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 2em 0 0.6em;
    padding-top: 0.4em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 1.6em 0 0.5em;
  }
  .prose :global(p) {
    color: var(--text-muted);
    margin: 0.9em 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    color: var(--text-muted);
    margin: 0.9em 0;
    padding-left: 1.3em;
    display: flex;
    flex-direction: column;
    gap: 0.45em;
  }
  .prose :global(ul) {
    list-style: none;
    padding-left: 0;
  }
  .prose :global(ul > li) {
    position: relative;
    padding-left: 1.4em;
  }
  .prose :global(ul > li)::before {
    content: ">";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-mono);
  }
  .prose :global(ol) {
    list-style: decimal;
    padding-left: 1.4em;
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(249, 119, 255, 0.4);
  }
  .prose :global(strong) {
    color: var(--text);
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--bg-elev-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.12em 0.45em;
    color: var(--orchid);
  }
  .prose :global(pre) {
    background: #0a0613;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 18px 20px;
    overflow-x: auto;
    margin: 1.2em 0;
    line-height: 1.7;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
    font-size: 0.84rem;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2em 0;
    font-size: 0.92rem;
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 9px 12px;
    border-bottom: 1px solid var(--line);
  }
  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .prose :global(td) {
    color: var(--text-muted);
  }
  .prose :global(td kbd) {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: var(--bg-elev-2);
    border: 1px solid var(--line-bright);
    border-bottom-width: 2px;
    border-radius: 6px;
    padding: 0.15em 0.5em;
    color: var(--text);
    white-space: nowrap;
  }
  .prose :global(.note) {
    border: 1px solid rgba(249, 119, 255, 0.28);
    background: rgba(249, 119, 255, 0.06);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    margin: 1.4em 0;
  }
  .prose :global(.note p) {
    margin: 0;
    color: var(--text);
    font-size: 0.92rem;
  }

  @media (max-width: 820px) {
    .docs {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .docs-side {
      position: static;
      border-bottom: 1px solid var(--line);
      padding-bottom: 20px;
    }
  }
</style>
