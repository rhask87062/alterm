---
import { SITE, ACK, url } from "../lib/site";
---

<footer class="site-footer">
  <div class="container">
    <hr class="rule" />
    <div class="cols">
      <div class="col brand-col">
        <a class="brand" href={url("/")}>
          <img src={url("/brand/alterm.png")} alt="" width="32" height="32" />
          <span>alterm</span>
        </a>
        <p class="muted">{SITE.tagline}</p>
        <p class="built">Built in Rust · v{SITE.version} · {SITE.license} License</p>
      </div>

      <div class="col">
        <h4>Project</h4>
        <ul>
          <li><a href={SITE.repo} target="_blank" rel="noopener">GitHub</a></li>
          <li><a href={url("/docs")}>Documentation</a></li>
          <li><a href={url("/#roadmap")}>Roadmap</a></li>
          <li>
            <a href={`${SITE.repo}/blob/main/LICENSE`} target="_blank" rel="noopener"
              >MIT License</a
            >
          </li>
        </ul>
      </div>

      <div class="col">
        <h4>Docs</h4>
        <ul>
          <li><a href={url("/docs/installation")}>Installation</a></li>
          <li><a href={url("/docs/configuration")}>Configuration</a></li>
          <li><a href={url("/docs/keybindings")}>Keybindings</a></li>
          <li><a href={url("/docs/ai")}>AI providers</a></li>
        </ul>
      </div>

      <div class="col">
        <h4>Built on</h4>
        <ul class="ack">
          {
            ACK.map((a) => (
              <li>
                <span class="ack-name">{a.name}</span>
                <span class="muted"> — {a.what}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <p class="copyright muted">
      © {new Date().getFullYear()} Russell Alan Haskell · Alterm is open source under the MIT
      License.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: 56px 40px;
    margin-top: 40px;
  }
  .cols {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: 40px;
    padding-block: 44px 30px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
  }
  .brand img {
    border-radius: 7px;
  }
  .muted {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .built {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    margin-top: 0.6em;
  }
  .brand-col p {
    margin-top: 0.7em;
    max-width: 34ch;
  }
  h4 {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 1em;
  }
  .col ul {
    display: flex;
    flex-direction: column;
    gap: 0.6em;
    font-size: 0.92rem;
  }
  .col a {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .col a:hover {
    color: var(--accent);
  }
  .ack {
    font-size: 0.84rem;
  }
  .ack-name {
    font-family: var(--font-mono);
    color: var(--text);
  }
  .copyright {
    font-size: 0.82rem;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }
  @media (max-width: 820px) {
    .cols {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 520px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }
</style>
